+				.rtd_init = asoc_sdw_cs_spk_feedback_rtd_init,
+			},
+		},
+		.dai_num = 2,
+	},
+	{
 		.part_id = 0x3563,
 		.dais = {
 			{
@@ -652,6 +678,43 @@
 		.dai_num = 4,
 	},
